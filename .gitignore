# basic .gitignore som täcker allting vi kan tänka oss och som ej läcker det viktiga och onödigt skräp


# --- Secrets & Credentials (CRITICAL) ---
.env
.env.*
!.env.example
!.env.template
# AWS/Cloud keys om de skulle råka hamna här
.aws/
secrets/

# --- Dependency Management (uv) ---
# Jag ignorerar miljön, men INTE uv.lock (den är min "truth")
.venv/
venv/
ENV/
env/
.python-version

# --- Python Core & Build Artifacts ---
__pycache__/
*.py[cod]
*$py.class
# Distribution / Packaging 
dist/
build/
*.egg-info/
.eggs/


# --- Code Quality & Testing ---
.ruff_cache/
.pytest_cache/
__pycache__/

# --- Data & Local Storage (SoC) ---
*.parquet
*.csv
*.json
*.duckdb
*.db

# --- Medallion Data Folders (ALDRIG I GIT) --- KAN KOMMA ATT ÄNDRAS VID BEHOV
#data/bronze/
#data/silver/
#data/gold/

# --- Local Databases ---
*.sqlite
*.sqlite3
*.db
*.duckdb
*.wal
*.journal


# --- IDE & Editor Junk ---
.vscode/
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json
.idea/
*.swp
*.swo